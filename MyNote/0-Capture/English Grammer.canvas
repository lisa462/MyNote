		{"id":"3cb6e724e0041203","type":"text","text":"動詞變化-過去-過去分詞\n動詞變化-現在分詞","x":726,"y":-43,"width":250,"height":60},
		{"id":"0be2958ec2c4fbb2","type":"text","text":"動詞規則變化\n直接+ed\n母音+y，ay/ey/iy/oy/uy，直接+ed\nCVC + 重複字尾+ed","x":1084,"y":-260,"width":250,"height":160},
		{"id":"27f4e090a881585b","type":"text","text":"動詞不規則變化，必背\ntoke-too-taket","x":1076,"y":-19,"width":250,"height":60,"color":"1"},
		{"id":"d21e1e4d8c720810","type":"text","text":"名詞和代名詞","x":175,"y":300,"width":250,"height":28},
